{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types" : [
      "mocha", "@wdio/types/globals", "node"
    ],
    "baseUrl": "./",
    "paths": {
      "@pages/*": ["./src/pages/*"]
    }
  },
  "include": ["src"]
}
