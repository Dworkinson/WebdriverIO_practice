{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "es2022",
    "resolveJsonModule": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "types" : [
      "mocha", "@wdio/globals", "node"
    ],
    "paths": {
      "@pages/*": ["./src/pages/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@data/*": ["./src/data/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["src"]
}
